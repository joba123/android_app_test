<resources>
    <style name="AppTheme" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">#0B0B0F</item>
        <item name="android:statusBarColor">#0B0B0F</item>
    </style>

    <style name="AppTheme.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0B0B0F</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_higher_lower_logo</item>
        <item name="windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/AppTheme</item>
    </style>
</resources>
